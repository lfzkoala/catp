{
  "name": "@catp-protocol/cli",
  "version": "0.2.1",
  "description": "Cryptographic Agent Trust Protocol — local enforcement plugin for Claude Code with TOML policy and tamper-evident audit log",
  "keywords": [
    "claude-code",
    "ai-agents",
    "policy",
    "audit",
    "hooks",
    "trust",
    "zk"
  ],
  "license": "MIT",
  "homepage": "https://github.com/lfzkoala/catp#readme",
  "bugs": "https://github.com/lfzkoala/catp/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lfzkoala/catp.git"
  },
  "type": "module",
  "bin": {
    "catp": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules ../node_modules/.bin/jest --config jest.config.cjs",
    "test:coverage": "node --experimental-vm-modules ../node_modules/.bin/jest --config jest.config.cjs --coverage --ci"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "micromatch": "^4.0.5",
    "smol-toml": "^1.3.0",
    "viem": "^2"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.6",
    "@types/node": "^20.19.39",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  }
}
