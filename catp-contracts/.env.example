# Layer 2 testnet deployment
#
# Copy to `.env` or export these values in your shell.
# Never commit real private keys or RPC credentials.

# Sepolia / Base Sepolia / Arbitrum Sepolia RPC URL.
CATP_RPC_URL=https://sepolia.example

# Deployer private key, 0x-prefixed.
CATP_PRIVATE_KEY=0x...

# Optional. Used only if you add verifier publishing flags.
ETHERSCAN_API_KEY=

